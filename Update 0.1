<!-- TOAST -->

<div id="toast">✅ <span id="toast-msg">Saved!</span></div>

<script>
// Page navigation
function showPage(id, el){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  document.querySelectorAll('.sb-item').forEach(i=>i.classList.remove('active'));
  if(el) el.classList.add('active');
  const titles = {overview:'OVERVIEW',agents:'LIVE AGENTS',script:'SCRIPT MANAGER',appointment:'APPOINTMENTS',calling:'CALLING SETUP',chatbot:'CHATBOT',settings:'SETTINGS'};
  document.getElementById('page-title').textContent = titles[id] || id.toUpperCase();
}

// Toast
function showToast(msg){
  const t=document.getElementById('toast');
  document.getElementById('toast-msg').textContent=msg;
  t.style.display='block';
  setTimeout(()=>{t.style.display='none';},3200);
}

// Script tabs
function switchScriptTab(tab, el){
  document.querySelectorAll('.script-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  ['basic','greeting','objections','closing','preview'].forEach(t=>{
    const el2=document.getElementById('stab-'+t);
    if(el2) el2.style.display = t===tab ? 'block' : 'none';
  });
}

// Save script
function saveScript(){
  const name = document.getElementById('script-name').value || 'My Script';
  showToast('Script "'+name+'" saved! ✅');
}

// Save biz data
function saveBizData(){
  const name = document.getElementById('biz-name').value || 'Your Business';
  showToast(name+' data saved! Agent ready 🤖');
}

// Link phone
function linkPhone(){
  const num = document.getElementById('phone-input').value;
  if(!num){showToast('Phone number enter karo ❌');return;}
  document.getElementById('linked-number').textContent = num;
  document.querySelector('.phone-status').textContent = '● Connected & Active';
  document.querySelector('.phone-status').style.color = '#10b981';
  showToast('Phone linked! OTP sent to '+num+' 📱');
}

// Add contact
function addContact(){
  const name=document.getElementById('new-contact-name').value;
  const phone=document.getElementById('new-contact-phone').value;
  if(!name||!phone){showToast('Name aur phone dono bharo ❌');return;}
  const list=document.getElementById('contact-list');
  const div=document.createElement('div');
  div.style.cssText='display:flex;gap:8px;background:#1e293b;border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:10px 12px;align-items:center;';
  div.innerHTML='<div style="flex:1"><div style="font-size:13px;font-weight:600">'+name+'</div><div style="font-size:11px;color:#64748b">'+phone+'</div></div><span style="padding:3px 10px;border-radius:100px;font-size:11px;font-weight:600;background:rgba(245,158,11,0.15);color:#f59e0b">Pending</span>';
  list.appendChild(div);
  document.getElementById('new-contact-name').value='';
  document.getElementById('new-contact-phone').value='';
  showToast(name+' added to call list! ✅');
}

// Start calling
function startCalling(){
  showToast('Auto calling started! Agent is dialing... 📞');
}

// Chat
const chatResponses = [
  'Bilkul! Main aapki madad kar sakta hoon. Aur kuch jaanna chahte hain?',
  'Yeh bahut accha sawaal hai! Hamare agents 24/7 available hain.',
  'Haan! Appointment book karne ke liye main abhi slot check karta hoon.',
  'Koi baat nahi! Main connect karta hoon humari team se.',
  'Bilkul samajh gaya. Kya main aapko callback schedule kar sakta hoon?'
];
let chatIdx = 0;
function sendChatMsg(){
  const input=document.getElementById('chat-input');
  const msg=input.value.trim();
  if(!msg) return;
  const chat=document.getElementById('chat-preview');
  chat.innerHTML+='<div style="background:#1e293b;border-radius:8px;padding:10px;max-width:85%;align-self:flex-end;margin-left:auto;"><div style="font-size:10px;color:#64748b;font-weight:700;margin-bottom:4px">YOU</div><div style="font-size:13px">'+msg+'</div></div>';
  input.value='';
  setTimeout(()=>{
    const resp=chatResponses[chatIdx % chatResponses.length]; chatIdx++;
    chat.innerHTML+='<div style="background:rgba(6,182,212,0.1);border-radius:8px;padding:10px;max-width:85%;align-self:flex-start;"><div style="font-size:10px;color:#06b6d4;font-weight:700;margin-bottom:4px">AGENTX BOT</div><div style="font-size:13px">'+resp+'</div></div>';
    chat.scrollTop=chat.scrollHeight;
  },800);
  chat.scrollTop=chat.scrollHeight;
}

// Save settings
function saveSettings(){
  const name=document.getElementById('set-name').value;
  document.getElementById('sb-username').textContent=name;
  document.getElementById('sb-avatar').textContent=name[0].toUpperCase();
  showToast('Settings saved! ✅');
}

// Trial timer
function startTimer(){
  const key='agentx_trial_start';
  let start=localStorage.getItem(key);
  if(!start){ start=Date.now(); localStorage.setItem(key,start); }
  const SEVEN_DAYS=7*24*60*60*1000;
  function update(){
    const rem=SEVEN_DAYS-(Date.now()-parseInt(start));
    if(rem<=0){
      document.getElementById('timer-display').textContent='Expired';
      if(document.getElementById('settings-timer'))
        document.getElementById('settings-timer').textContent='Expired';
      return;
    }
    const d=Math.floor(rem/(1000*60*60*24));
    const h=Math.floor((rem%(1000*60*60*24))/(1000*60*60));
    const m=Math.floor((rem%(1000*60*60))/(1000*60));
    const s=Math.floor((rem%(1000*60))/1000);
    const str=d+'d '+h+'h '+m+'m '+s+'s';
    document.getElementById('timer-display').textContent=str;
    if(document.getElementById('settings-timer'))
      document.getElementById('settings-timer').textContent=str;
  }
  update();
  setInterval(update,1000);
}

// Load user info
window.addEventListener('load',function(){
  startTimer();
  const user=JSON.parse(localStorage.getItem('agentx_user')||'{}');
  if(user.name){
    document.getElementById('sb-username').textContent=user.name;
    document.getElementById('sb-avatar').textContent=user.name[0].toUpperCase();
    if(document.getElementById('set-name')) document.getElementById('set-name').value=user.name;
    if(document.getElementById('set-email') && user.email) document.getElementById('set-email').value=user.email;
    document.getElementById('sb-useremail').textContent=user.email||'';
  }
});
</script>

