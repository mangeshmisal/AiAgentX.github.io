<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AgentX Dashboard</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Bebas+Neue&display=swap');
:root{--bg:#030712;--card:#0f172a;--card2:#1e293b;--border:rgba(255,255,255,0.07);--cyan:#06b6d4;--violet:#8b5cf6;--green:#10b981;--orange:#f59e0b;--red:#ef4444;--text:#f1f5f9;--muted:#64748b;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Space Grotesk',sans-serif;display:flex;min-height:100vh;}

/* SIDEBAR */
.sidebar{width:240px;background:var(–card);border-right:1px solid var(–border);display:flex;flex-direction:column;padding:0;position:fixed;top:0;left:0;bottom:0;z-index:100;}
.sb-logo{padding:24px 20px;border-bottom:1px solid var(–border);}
.sb-logo a{font-family:‘Bebas Neue’,sans-serif;font-size:26px;letter-spacing:2px;color:var(–text);text-decoration:none;}
.sb-logo a em{color:var(–cyan);font-style:normal;}
.sb-logo .trial-badge{display:inline-block;background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.3);color:var(–green);font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;margin-top:6px;letter-spacing:1px;}
.sb-nav{flex:1;padding:16px 0;overflow-y:auto;}
.sb-section{font-size:10px;color:var(–muted);text-transform:uppercase;letter-spacing:2px;padding:12px 20px 6px;}
.sb-item{display:flex;align-items:center;gap:12px;padding:11px 20px;font-size:14px;color:var(–muted);cursor:pointer;transition:all 0.2s;border-left:3px solid transparent;}
.sb-item:hover{color:var(–text);background:rgba(255,255,255,0.03);}
.sb-item.active{color:var(–cyan);background:rgba(6,182,212,0.07);border-left-color:var(–cyan);}
.sb-item .dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.sb-item .dot.on{background:var(–green);box-shadow:0 0 6px var(–green);}
.sb-item .dot.off{background:var(–muted);}
.sb-footer{padding:16px 20px;border-top:1px solid var(–border);}
.sb-user{display:flex;align-items:center;gap:10px;}
.sb-avatar{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(–cyan),var(–violet));display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#000;flex-shrink:0;}
.sb-name{font-size:13px;font-weight:600;}
.sb-email{font-size:11px;color:var(–muted);}

/* MAIN */
.main{margin-left:240px;flex:1;display:flex;flex-direction:column;min-height:100vh;}
.topbar{padding:16px 32px;border-bottom:1px solid var(–border);display:flex;align-items:center;justify-content:space-between;background:rgba(3,7,18,0.8);backdrop-filter:blur(20px);position:sticky;top:0;z-index:50;}
.topbar-title{font-family:‘Bebas Neue’,sans-serif;font-size:24px;letter-spacing:1px;}
.topbar-right{display:flex;align-items:center;gap:12px;}
.trial-timer-sm{background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.25);border-radius:8px;padding:6px 14px;font-size:12px;color:var(–green);font-weight:600;}

/* PAGE CONTENT */
.page{padding:28px 32px;display:none;}
.page.active{display:block;}

/* CARDS */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;}
.kpi-card{background:var(–card);border:1px solid var(–border);border-radius:14px;padding:20px;}
.kpi-label{font-size:11px;color:var(–muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.kpi-val{font-family:‘Bebas Neue’,sans-serif;font-size:38px;letter-spacing:1px;}
.kpi-sub{font-size:11px;color:var(–muted);margin-top:4px;}
.kpi-card.cyan .kpi-val{color:var(–cyan);}
.kpi-card.green .kpi-val{color:var(–green);}
.kpi-card.violet .kpi-val{color:var(–violet);}
.kpi-card.orange .kpi-val{color:var(–orange);}

.section-title{font-family:‘Bebas Neue’,sans-serif;font-size:22px;letter-spacing:1px;margin-bottom:16px;}

/* AGENTS LIST */
.agents-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:28px;}
.agent-card{background:var(–card);border:1px solid var(–border);border-radius:14px;padding:20px;}
.agent-head{display:flex;align-items:center;gap:12px;margin-bottom:16px;}
.agent-avatar{width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,var(–cyan),var(–violet));display:flex;align-items:center;justify-content:center;font-size:18px;}
.agent-info{flex:1;}
.agent-name{font-size:15px;font-weight:700;}
.agent-type{font-size:11px;color:var(–muted);margin-top:2px;}
.status-badge{padding:4px 10px;border-radius:100px;font-size:11px;font-weight:700;}
.status-live{background:rgba(16,185,129,0.15);color:var(–green);border:1px solid rgba(16,185,129,0.3);}
.status-idle{background:rgba(100,116,139,0.15);color:var(–muted);border:1px solid rgba(100,116,139,0.2);}
.status-busy{background:rgba(245,158,11,0.15);color:var(–orange);border:1px solid rgba(245,158,11,0.3);}
.agent-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.agent-stat{background:var(–card2);border-radius:8px;padding:10px;text-align:center;}
.agent-stat-n{font-family:‘Bebas Neue’,sans-serif;font-size:22px;color:var(–cyan);}
.agent-stat-l{font-size:10px;color:var(–muted);}
.agent-actions{display:flex;gap:8px;margin-top:14px;}

/* BUTTONS */
.btn{padding:9px 18px;border-radius:8px;font-family:‘Space Grotesk’,sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s;border:none;display:inline-flex;align-items:center;gap:6px;}
.btn-cyan{background:var(–cyan);color:#000;}
.btn-cyan:hover{background:#fff;}
.btn-outline{background:transparent;border:1px solid var(–border);color:var(–text);}
.btn-outline:hover{border-color:var(–cyan);color:var(–cyan);}
.btn-red{background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:var(–red);}
.btn-green{background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.3);color:var(–green);}
.btn-violet{background:rgba(139,92,246,0.15);border:1px solid rgba(139,92,246,0.3);color:var(–violet);}

/* WAVE */
.wave{display:flex;align-items:center;gap:3px;height:24px;}
.wbar{width:3px;border-radius:2px;background:var(–cyan);animation:wv 1.2s ease-in-out infinite;}
@keyframes wv{0%,100%{height:4px;opacity:0.4;}50%{height:20px;opacity:1;}}
.wbar:nth-child(1){animation-delay:0s}.wbar:nth-child(2){animation-delay:0.1s}.wbar:nth-child(3){animation-delay:0.2s}.wbar:nth-child(4){animation-delay:0.3s}.wbar:nth-child(5){animation-delay:0.2s}.wbar:nth-child(6){animation-delay:0.1s}

/* SCRIPT EDITOR */
.script-editor{background:var(–card);border:1px solid var(–border);border-radius:14px;overflow:hidden;}
.script-tabs{display:flex;border-bottom:1px solid var(–border);background:var(–card2);}
.script-tab{padding:12px 20px;font-size:13px;font-weight:600;color:var(–muted);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;}
.script-tab.active{color:var(–cyan);border-bottom-color:var(–cyan);}
.script-body{padding:24px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
.form-group{display:flex;flex-direction:column;gap:6px;}
.form-label{font-size:12px;font-weight:600;color:var(–muted);text-transform:uppercase;letter-spacing:1px;}
.form-input{background:var(–card2);border:1px solid var(–border);border-radius:10px;padding:12px 14px;color:var(–text);font-size:14px;font-family:‘Space Grotesk’,sans-serif;outline:none;transition:border-color 0.2s;}
.form-input:focus{border-color:var(–cyan);}
.form-textarea{background:var(–card2);border:1px solid var(–border);border-radius:10px;padding:12px 14px;color:var(–text);font-size:14px;font-family:‘Space Grotesk’,sans-serif;outline:none;resize:vertical;min-height:120px;transition:border-color 0.2s;}
.form-textarea:focus{border-color:var(–cyan);}
.form-select{background:var(–card2);border:1px solid var(–border);border-radius:10px;padding:12px 14px;color:var(–text);font-size:14px;font-family:‘Space Grotesk’,sans-serif;outline:none;appearance:none;cursor:pointer;}
.form-select:focus{border-color:var(–cyan);}
input::placeholder,textarea::placeholder{color:#475569;}

/* SCRIPT FLOW */
.flow-container{display:flex;flex-direction:column;gap:0;margin-top:16px;}
.flow-node{display:flex;gap:16px;position:relative;}
.flow-line{display:flex;flex-direction:column;align-items:center;gap:0;}
.flow-dot{width:32px;height:32px;border-radius:50%;border:2px solid var(–cyan);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(–cyan);background:var(–bg);flex-shrink:0;z-index:1;}
.flow-connector{width:2px;flex:1;min-height:20px;background:linear-gradient(var(–cyan),transparent);margin:0 auto;}
.flow-content{flex:1;background:var(–card2);border:1px solid var(–border);border-radius:10px;padding:14px;margin-bottom:12px;}
.flow-content h4{font-size:13px;font-weight:700;margin-bottom:4px;}
.flow-content p{font-size:12px;color:var(–muted);line-height:1.5;}

/* APPOINTMENT */
.apt-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.apt-calendar{background:var(–card);border:1px solid var(–border);border-radius:14px;padding:20px;}
.cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.cal-title{font-family:‘Bebas Neue’,sans-serif;font-size:20px;letter-spacing:1px;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;text-align:center;}
.cal-day-header{font-size:10px;color:var(–muted);padding:4px 0;text-transform:uppercase;}
.cal-day{padding:8px 4px;border-radius:6px;font-size:13px;cursor:pointer;transition:all 0.2s;}
.cal-day:hover{background:rgba(6,182,212,0.1);color:var(–cyan);}
.cal-day.today{background:var(–cyan);color:#000;font-weight:700;}
.cal-day.booked{background:rgba(139,92,246,0.15);color:var(–violet);}
.cal-day.empty{opacity:0;}
.apt-list{background:var(–card);border:1px solid var(–border);border-radius:14px;padding:20px;display:flex;flex-direction:column;gap:10px;}
.apt-item{background:var(–card2);border:1px solid var(–border);border-radius:10px;padding:14px;display:flex;align-items:center;gap:12px;}
.apt-time{font-family:‘Bebas Neue’,sans-serif;font-size:18px;color:var(–cyan);min-width:60px;}
.apt-info{flex:1;}
.apt-name{font-size:13px;font-weight:700;}
.apt-detail{font-size:11px;color:var(–muted);margin-top:2px;}

/* PHONE LINK */
.phone-setup{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.phone-card{background:var(–card);border:1px solid var(–border);border-radius:14px;padding:24px;}
.phone-number-display{background:var(–card2);border:1px solid rgba(6,182,212,0.3);border-radius:12px;padding:20px;text-align:center;margin-bottom:20px;}
.phone-num{font-family:‘Bebas Neue’,sans-serif;font-size:32px;letter-spacing:2px;color:var(–cyan);}
.phone-status{font-size:11px;color:var(–green);margin-top:4px;}

/* CALL LOG */
.call-log{background:var(–card);border:1px solid var(–border);border-radius:14px;overflow:hidden;}
.call-log-header{padding:16px 20px;border-bottom:1px solid var(–border);display:flex;align-items:center;justify-content:space-between;}
.call-table{width:100%;border-collapse:collapse;}
.call-table th{padding:10px 16px;text-align:left;font-size:10px;color:var(–muted);text-transform:uppercase;letter-spacing:1px;border-bottom:1px solid var(–border);}
.call-table td{padding:12px 16px;font-size:13px;border-bottom:1px solid rgba(255,255,255,0.03);}
.call-table tr:hover td{background:rgba(255,255,255,0.02);}
.call-result{padding:3px 10px;border-radius:100px;font-size:11px;font-weight:600;}
.result-success{background:rgba(16,185,129,0.15);color:var(–green);}
.result-missed{background:rgba(239,68,68,0.15);color:var(–red);}
.result-pending{background:rgba(245,158,11,0.15);color:var(–orange);}

/* TOAST */
#toast{display:none;position:fixed;bottom:24px;right:24px;z-index:9999;background:#10b981;color:#fff;padding:14px 20px;border-radius:10px;font-size:13px;font-weight:600;box-shadow:0 8px 32px rgba(16,185,129,0.3);animation:slideIn 0.3s ease;}
@keyframes slideIn{from{opacity:0;transform:translateX(20px);}to{opacity:1;transform:translateX(0);}}

/* Responsive */
@media(max-width:768px){
.sidebar{width:60px;}
.sb-logo a span,.sb-name,.sb-email,.sb-section,.sb-item span{display:none;}
.main{margin-left:60px;}
.kpi-row{grid-template-columns:1fr 1fr;}
.agents-grid,.apt-grid,.phone-setup,.form-row{grid-template-columns:1fr;}
}
</style>

</head>
